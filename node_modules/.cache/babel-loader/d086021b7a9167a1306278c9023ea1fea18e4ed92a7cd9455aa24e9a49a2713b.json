2\\u0430\\u0435\\u043C \\u043A\\u043E\\u043C\\u0430\\u043D\\u0434\\u043E\\u0439 \\u043F\\u0440\\u043E\\u0444\\u0435\\u0441\\u0441\\u0438\\u043E\\u043D\\u0430\\u043B\\u043E\\u0432,\", /*#__PURE__*/_jsxDEV(\"br\", {}, void 0, false, {\n        fileName: _jsxFileName,\n        lineNumber: 20,\n        columnNumber: 204\n      }, this), \"\\u043E\\u043F\\u0438\\u0440\\u0430\\u044F\\u0441\\u044C \\u043D\\u0430 \\u043D\\u0430\\u043A\\u043E\\u043F\\u043B\\u0435\\u043D\\u043D\\u044B\\u0439 \\u043E\\u043F\\u044B\\u0442, \\u0443\\u0434\\u0435\\u043B\\u044F\\u044F \\u043E\\u0441\\u043E\\u0431\\u043E\\u0435 \\u0432\\u043D\\u0438\\u043C\\u0430\\u043D\\u0438\\u0435 \\u0432\\u043E\\u0432\\u043B\\u0435\\u0447\\u0435\\u043D\\u043D\\u043E\\u0441\\u0442\\u0438 \\u0438 \\u0434\\u043E\\u0441\\u0442\\u0438\\u0436\\u0435\\u043D\\u0438\\u044F\\u043C \\u043A\\u0430\\u0436\\u0434\\u043E\\u0433\\u043E \\u0441\\u043E\\u0442\\u0440\\u0443\\u0434\\u043D\\u0438\\u043A\\u0430.\"]\n    }, void 0, true, {\n      fileName: _jsxFileName,\n      lineNumber: 19,\n      columnNumber: 7\n    }, this)]\n  }, void 0, true, {\n    fileName: _jsxFileName,\n    lineNumber: 6,\n    columnNumber: 5\n  }, this);\n};\n_c = AboutCompany;\nexport default _c2 = /*#__PURE__*/React.memo(AboutCompany);\nvar _c, _c2;\n$RefreshReg$(_c, \"AboutCompany\");\n$RefreshReg$(_c2, \"%default%\");","map":{"version":3,"names":["React","styles","jsxDEV","_jsxDEV","AboutCompany","className","aboutCompany","children","aboutCompanyText","fileName","_jsxFileName","lineNumber","columnNumber","_c","_c2","memo","$RefreshReg$"],"sources":["/home/qookiefaitpipi/Документы/qookieFaitPipi/webProject/transproject/src/pages/IndexPage/AboutCompany/AboutCompany.jsx"],"sourcesContent":["import React from \"react\";\nimport styles from './AboutCompany.module.scss';\n\nconst AboutCompany = () => {\n  return(\n    <div className={styles.aboutCompany}>\n      <p className={styles.aboutCompanyText}>\n        ООО «ТранспроектИнжиниринг» - команда профессионалов в области транспортного<br/>\n        планирования и комплексного проектирования автомобильных дорог и объектов транспортной инфраструктуры.\n      </p>\n      <p className={styles.aboutCompanyText}>\n        Сотрудники компании имеют многолетний опыт успешной работы с государственными заказчиками и частными инвесторами<br/>\n        на объектах транспортного строительства Северо-Западного, Центрального, Приволжского федеральных округов, Краснодарского края, Крыма, Сибири и Дальнего Востока.\n      </p>\n      <p className={styles.aboutCompanyText}>\n        <b>Наша задача</b> – обеспечение успешной реализации проекта на всех этапах его жизненного цикла, выработка грамотных технологических и конструктивных решений в партнерстве<br/>\n        с заказчиком и подрядчиком, а также результативная защита и сопровождение принятых проектных решений в контрольно-надзорных органах, экологической и государственной экспертизе.\n      </p>\n      <p className={styles.aboutCompanyText}>\n        <b>Наша миссия</b> – созидательная деятельность, способствующая развитию транспортной инфраструктуры, повышению качества жизни людей, защите окружающей среды. Мы работаем командой профессионалов,<br/>\n        опираясь на накопленный опыт, уделяя особое внимание вовлеченности и достижениям каждого сотрудника.\n      </p>\n    </div>\n  );\n}\n\nexport default React.memo(AboutCompany);"],"mappings":";AAAA,OAAOA,KAAK,MAAM,OAAO;AACzB,OAAOC,MAAM,MAAM,4BAA4B;AAAC,SAAAC,MAAA,IAAAC,OAAA;AAEhD,MAAMC,YAAY,GAAGA,CAAA,KAAM;EACzB,oBACED,OAAA;IAAKE,SAAS,EAAEJ,MAAM,CAACK,YAAa;IAAAC,QAAA,gBAClCJ,OAAA;MAAGE,SAAS,EAAEJ,MAAM,CAACO,gBAAiB;MAAAD,QAAA,GAAC,8ZACuC,eAAAJ,OAAA;QAAAM,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,QAAK,sjBAEnF;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,QAAI,eACJT,OAAA;MAAGE,SAAS,EAAEJ,MAAM,CAACO,gBAAiB;MAAAD,QAAA,GAAC,smBAC2E,eAAAJ,OAAA;QAAAM,QAAA,EAAAC,YAAA;QAAAC,UAAA;QAAAC,YAAA;MAAA,QAAK,s1BAEvH;IAAA;MAAAH,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,QAAI,eACJT,OAAA;